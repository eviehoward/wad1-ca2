<form class="ui stacked segment form" action="/dashboard/addCollection" method="POST" enctype="multipart/form-data">
<h3>Add a Collection</h3>
  <div class="two fields">
  <div class="field">
    <label>Title</label>
    <input placeholder="Title" type="text" name="title" required>
  </div>
  <div class="field">
      <label>Image</label>
      <input placeholder="Image" type="file" name="image" required>
    </div>
    </div>
 <button class="ui blue submit button">Add Collection</button>
</form>
