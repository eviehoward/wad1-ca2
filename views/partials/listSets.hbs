<img src="{{image.url}}" class="ui medium middle aligned image" />

{{#if sets}}

<p>{{sets.length}} sets total.</p>



<table class="ui unstackable striped table">
  <thead>
    <tr>
      <th><i class="ui clipboard list icon"></i>Code</th>
      <th>Name</th>
      <th><i class="ui puzzle piece icon"></i>Pieces</th>
      <th><i class="ui piggy bank icon"></i>RRP</th>
      <th>Image</th>
      <th></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{#each sets}}
      {{> listOneSet collectionId=../id}}
      {{> editSet collectionId=../id}}
    
    <script>
      document.querySelector("#showEdit{{@index}}").addEventListener ('click', () => {
          document.querySelector("#set{{@index}}").style.display = "none";
          document.querySelector("#edit{{@index}}").style.display = "table-row";
      })
      document.querySelector("#hideEdit{{@index}}").addEventListener ('click', () => {
          document.querySelector("#set{{@index}}").style.display = "table-row";
          document.querySelector("#edit{{@index}}").style.display = "none";
      })
    </script>

    {{/each}}
  </tbody>
</table>

{{else}}
<h3>This collection has no sets yet.</h3>

{{/if}}
