<hr />

<section class="ui left aligned middle aligned segment">
    <section class="dashboard-header">
        <h2 class="title">Lego Collections</h2>

        <form action="/searchCategory" method="GET" class="ui form">
        <div class="ui inline fields">
            <div class="field">
                <input type="text" name="searchTerm" placeholder="Search by title..." value="{{search}}">
            </div>
            
            <div class="field">
                <label>Sort by: </label>
                <select class="ui dropdown" name="sort" onchange="this.form.submit()">
                    <option value="title" {{#if titleSelected}}selected{{/if}}>Title</option>
                    <option value="size" {{#if sizeSelected}}selected{{/if}}>Size</option>
                </select>
            </div>

            <div class="field">
                <label>Order:</label>
                <select class="ui dropdown" name="order" onchange="this.form.submit()">
                    <option value="asc" {{#if ascSelected}}selected{{/if}}>↑</option>
                    <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
                </select>
            </div>
        </div>
        </form>
    </section>

    {{#unless search}}
    {{#unless legoCollections}}
    <h3 class="ui message">There are no lego collections yet.</h3>
    {{/unless}}
    {{/unless}}
    
    {{#each legoCollections}}
    <section class="ui left aligned middle aligned segment">
        <h3 class="ui header">{{countNormal @index}}: Lego {{properCase title}}</h3>
        <img src="{{image.url}}" alt="{{properCase title}} logo" class="ui right floated medium image" />

        {{#if sets}}
        <p><i class="ui smile icon"></i>Sets: {{sets.length}}</p>
        {{else}}
        <p><i class="ui dizzy icon"></i>Empty collection!</p>
        {{/if}}

        {{#if date}}
        <p><i class="ui calendar alternate icon"></i>Created on: {{formatDate date}}</p>
        {{/if}}

        <a href="/legoCollection/{{id}}"> <i class="ui circular hand point right outline icon"></i> </a>
        <a href="/dashboard/deletecollection/{{id}}">
            <i class="ui trash black icon"></i>
        </a>


        <div class="ui clearing hidden divider"></div>
    </section>

    {{/each}}
</section>


<div class="break"></div>
