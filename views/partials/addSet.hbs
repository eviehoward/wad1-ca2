<form
  class="ui stacked segment form"
  action="/legoCollection/{{id}}/addSet"
  method="POST"
  enctype="multipart/form-data">
  <div class="two fields">
    <div class="field">
      <label>Name</label>
      <input type="text" name="name"  required title="Please include a valid Title" placeholder="Name" />
    </div>
    <div class="field">
      <label>Code</label>
      <input
        type="text"
        name="code"
        pattern="\d{5}"
        
        required
        title="Please include a valid Code (5 digits)"
        placeholder="12345" />
    </div>
  </div>

  <div class="three fields">
    <div class="field">
      <label>Pieces</label>
      <input type="number" name="pieces"  required title="Please include a valid number" placeholder="0" />
    </div>
    <div class="field">
      <label>Price</label>
      <input type="text" name="price"  required title="Please include a valid price" placeholder="0.00" />
    </div>
    <div class="field">
      <label>Image</label>
      <input type="file" placeholder="Image" name="picture" required />
    </div>
  </div>
  <button class="ui blue submit button">Add Set</button>
</form>
